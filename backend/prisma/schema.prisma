generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          BigInt     @id @default(autoincrement())
  name        String     @unique
  description String?
  created     DateTime   @default(now())
  updated     DateTime?  @updatedAt
  created_by  BigInt?
  updated_by  BigInt?
  deleted     Boolean    @default(false)
  active      Boolean    @default(true)
  users       UserRole[]

  @@map("roles")
}

model User {
  id         BigInt     @id @default(autoincrement())
  username   String?    @unique
  email      String     @unique
  password   String
  name       String?
  img        String?
  created    DateTime   @default(now())
  updated    DateTime?  @updatedAt
  created_by BigInt?
  updated_by BigInt?
  deleted    Boolean    @default(false)
  active     Boolean    @default(true)
  orders     Order[]
  roles      UserRole[]

  @@index([id], map: "idx_users_active", where: raw("((deleted = false) AND (active = true))"))
  @@map("users")
}

model UserRole {
  user_id    BigInt
  role_id    BigInt
  created    DateTime  @default(now())
  updated    DateTime? @updatedAt
  created_by BigInt?
  updated_by BigInt?
  deleted    Boolean   @default(false)
  active     Boolean   @default(true)
  role       Role      @relation(fields: [role_id], references: [id])
  user       User      @relation(fields: [user_id], references: [id])

  @@id([user_id, role_id])
  @@map("user_roles")
}

model Category {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique
  created    DateTime   @default(now())
  updated    DateTime?  @updatedAt
  created_by BigInt?
  updated_by BigInt?
  deleted    Boolean    @default(false)
  active     Boolean    @default(true)
  menu_items MenuItem[]

  @@map("categories")
}

model MenuItem {
  id          BigInt      @id @default(autoincrement())
  category_id BigInt?
  name        String
  description String?
  price       Decimal     @db.Decimal(12, 2)
  image       String?
  rating      Decimal?    @db.Decimal(2, 1)
  tag         String?
  created     DateTime    @default(now())
  updated     DateTime?   @updatedAt
  created_by  BigInt?
  updated_by  BigInt?
  deleted     Boolean     @default(false)
  active      Boolean     @default(true)
  category    Category?   @relation(fields: [category_id], references: [id])
  order_items OrderItem[]

  @@index([category_id], map: "idx_menu_items_active", where: raw("(deleted = false)"))
  @@map("menu_items")
}

model Order {
  id                BigInt      @id @default(autoincrement())
  customer_id       BigInt?
  ticket_number     String      @unique
  table_number      String
  status            String      @default("Received")
  wait_level        String?
  wait_time_minutes Int?
  created           DateTime    @default(now())
  updated           DateTime?   @updatedAt
  created_by        BigInt?
  updated_by        BigInt?
  deleted           Boolean     @default(false)
  active            Boolean     @default(true)
  is_paid           Boolean?    @default(false)
  payment_method    String?     @db.VarChar(20)
  paid_at           DateTime?   @db.Timestamp(6)
  total             Int?
  items             OrderItem[]
  customer          User?       @relation(fields: [customer_id], references: [id])

  @@map("orders")
}

model OrderItem {
  id             BigInt    @id @default(autoincrement())
  order_id       BigInt
  menu_item_id   BigInt
  name_at_order  String
  qty            Int
  price_at_order Decimal   @db.Decimal(12, 2)
  modifications  String[]
  created        DateTime  @default(now())
  updated        DateTime? @updatedAt
  created_by     BigInt?
  updated_by     BigInt?
  deleted        Boolean   @default(false)
  active         Boolean   @default(true)
  menu_item      MenuItem  @relation(fields: [menu_item_id], references: [id])
  order          Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}
