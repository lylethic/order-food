# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/ordering_food?schema=public"

# JWT Secret (use a long random string in production, e.g. openssl rand -hex 32)
JWT_SECRET="your-development-secret-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server port (default: 3001)
PORT=3001

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# QR Code HMAC secret — change this to rotate ALL table QR codes
# Generate a strong secret: openssl rand -hex 32
QR_SECRET="your-qr-secret-key-change-in-production-min-32-chars"
